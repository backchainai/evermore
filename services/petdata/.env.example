# petdata configuration. Copy to .env and adjust. All variables use the
# PETDATA_ prefix (pydantic-settings).

# --- Database (Supabase Postgres + pgvector) ---
# Async SQLAlchemy connection URL. postgres:// and postgresql:// are accepted
# and normalized to postgresql+asyncpg:// at runtime.
# The local default points at the pgvector container in docker-compose.test.yml.
PETDATA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/petdata_test

# Enforce SSL on the database connection. Leave false locally; set true in
# production (Supabase / Cloud Run).
PETDATA_DATABASE_REQUIRE_SSL=false

# --- Web server ---
PETDATA_DEBUG=true
PETDATA_ALLOWED_ORIGINS=["http://localhost:5173"]

# --- Source Shelter Management System (SMS) extraction ---
# Credentials and endpoints for the shelter system petdata extracts from.
PETDATA_COOKIES=your-sms-session-cookies
PETDATA_SMS_BASE_URL=https://your-sms-host.example.com/tables
PETDATA_SMS_TABLE_ANIMALS=table-id-animals
PETDATA_SMS_TABLE_VOLUNTEER_NOTES=table-id-volunteer-notes
PETDATA_SMS_TABLE_WALK_RECORDS=table-id-walk-records

# Throttle between extraction API requests (milliseconds).
PETDATA_REQUEST_DELAY_MS=500

# --- HTTP client (optional; defaults shown) ---
PETDATA_RETRY_MAX_ATTEMPTS=3
PETDATA_RETRY_BACKOFF_FACTOR=2.0
PETDATA_RETRY_MAX_DELAY_MS=10000
PETDATA_API_TIMEOUT_SECONDS=30.0
