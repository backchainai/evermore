# Retriever service environment. Copy to .env and fill in secrets.
# Backend reads this root .env via pydantic-settings.

# Database — pgvector container from apps/stacker/docker-compose.yml (host port 5433).
# Alembic rewrites the scheme to asyncpg automatically; the +asyncpg form also works directly.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/retriever

# --- Database connection pool ---
# Env-driven per deployment target (local vs Containers behind Hyperdrive).
# Defaults shown preserve prior behavior.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30.0
DB_POOL_RECYCLE=-1
DB_POOL_PRE_PING=true

# Supabase auth — values from: supabase status -o json (run in apps/stacker).
# Only SUPABASE_URL is needed to validate user tokens (JWKS); the keys are for
# admin/service operations and are optional for the local chat demo.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Langfuse (LLM observability: optional; no-op when unset)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# LLM gateway (required; app fails fast at startup if unset).
# Default: Cloudflare AI Gateway, derived from account + gateway IDs.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_ID=
# Override to use any other OpenAI-compatible gateway.
# LLM_GATEWAY_URL=
# BYOK token; provider keys live in the gateway, not here.
LLM_GATEWAY_TOKEN=
# Header that carries LLM_GATEWAY_TOKEN (sent only when the token is set).
# Default cf-aig-authorization (Cloudflare); change it for other gateways.
# LLM_GATEWAY_AUTH_HEADER=cf-aig-authorization

# GCP (optional)
GCP_PROJECT_ID=

# OpenTelemetry — leave empty for local dev (no collector running by default).
OTEL_EXPORTER_OTLP_ENDPOINT=

# App
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173"]
