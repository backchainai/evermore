# OS / editor
.DS_Store

# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / SvelteKit
node_modules/
.svelte-kit/
build/
.wrangler/

# Env / secrets
.env
.env.*
!.env.example

# Third-party research papers: copyright-protected, not ours to redistribute, and
# heavy binaries. Kept on disk and indexed at runtime from a private store. Our own
# derived work (docs/research/extractions, README, manifest) stays tracked.
/docs/research/source-research/
/docs/research/reference-library/

# Retired tooling cruft (Beads retired for Evermore per ADR 0002)
.beads/
.daedalus/

# Claude Code local session state (logs, worktrees): per-machine, not source
.claude/

# Ephemeral working memory (engram /working checkpoints): per-session, not source
.memory/

# Logs
*.log

# Makefile local dev run state (retriever pid/log from `make dev`)
.dev/

# Supabase CLI local state (generated by `supabase start`)
**/supabase/.branches/
**/supabase/.temp/
