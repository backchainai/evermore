# SvelteKit public env vars (PUBLIC_ prefix exposes to browser)
# Get Supabase values from: supabase status -o json
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend service URLs
PUBLIC_RETRIEVER_API_URL=http://localhost:8001
PUBLIC_PETDATA_API_URL=http://localhost:8002
